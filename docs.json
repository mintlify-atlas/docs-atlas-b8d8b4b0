{
  "$schema": "https://mintlify.com/docs.json",
  "name": "CodeMirror Vim",
  "theme": "palm",
  "colors": {
    "primary": "#cb0404",
    "light": "#f3d2d2",
    "dark": "#e37b84"
  },
  "favicon": "https://media.brand.dev/7316e6d5-0198-4785-94cd-cb9b972e0c98.png",
  "logo": {
    "light": "https://media.brand.dev/7316e6d5-0198-4785-94cd-cb9b972e0c98.png",
    "dark": "https://media.brand.dev/d0bd54b1-0a8c-48a1-8fc0-be53e565a398.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/replit/codemirror-vim"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/replit/codemirror-vim"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/key-mappings",
              "guides/ex-commands",
              "guides/custom-operators",
              "guides/visual-mode",
              "guides/status-bar"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "migration/from-cm5"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/vim",
              "api/get-cm"
            ]
          },
          {
            "group": "Vim API",
            "pages": [
              "api/vim-map",
              "api/vim-unmap",
              "api/vim-define-ex",
              "api/vim-define-operator",
              "api/vim-define-action",
              "api/vim-define-motion",
              "api/vim-handle-key",
              "api/vim-exit-insert-mode"
            ]
          }
        ]
      }
    ]
