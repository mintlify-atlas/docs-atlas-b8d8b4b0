  "keyFeatures": [
    "Complete Vim keybindings for CodeMirror 6",
    "Support for normal, visual, and insert modes",
    "Custom key mappings with Vim.map() and Vim.unmap()",
    "Define custom ex commands, operators, actions, and motions",
    "CM5 Vim API compatibility layer",
    "Visual block and line selection support",
    "Optional status bar showing current mode",
    "Event system for mode changes and key handling"
  ],
  "publicApiSurface": [
    "vim(options?)",
    "Vim.map(keys, mapping, context?)",
    "Vim.unmap(keys, context?)",
    "Vim.defineEx(name, prefix, callback)",
    "Vim.defineOperator(name, callback)",
    "Vim.defineAction(name, callback)",
    "Vim.defineMotion(name, callback)",
    "Vim.handleKey(cm, key, origin?)",
    "Vim.exitInsertMode(cm)",
    "getCM(view)"
  ]
